{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "jsx": "react-jsx",
    "lib": ["ES2022", "DOM"],
    "baseUrl": ".",
    "paths": {
      "@/*": ["./src/*"]
    },
    "types": ["expo/types"]
  },
  "include": ["src/**/*", "app/**/*", "*.ts", "*.tsx"],
  "exclude": ["node_modules"]
}
