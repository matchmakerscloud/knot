# =============================================================================
# Knot — Environment variables
# =============================================================================
# Copy this file to .env and fill in real values for local development.
# Never commit .env. Production secrets live in Doppler / AWS Secrets Manager.
# =============================================================================

# --- Application ---
NODE_ENV=development
APP_BASE_URL=http://localhost:3000
API_BASE_URL=http://localhost:4000
WEB_BASE_URL=http://localhost:3001
ADMIN_BASE_URL=http://localhost:3002

# --- Database ---
DATABASE_URL=postgres://knot:knot@localhost:5432/knot
DATABASE_POOL_SIZE=10

# --- Redis ---
REDIS_URL=redis://localhost:6379

# --- Object Storage (S3 / MinIO) ---
S3_ENDPOINT=http://localhost:9000
S3_REGION=us-east-1
S3_BUCKET=knot-dev
S3_ACCESS_KEY_ID=minioadmin
S3_SECRET_ACCESS_KEY=minioadmin
S3_FORCE_PATH_STYLE=true

# --- Auth ---
JWT_ACCESS_SECRET=change_me_run_openssl_rand_hex_64
JWT_REFRESH_SECRET=change_me_run_openssl_rand_hex_64
JWT_ACCESS_TTL_SECONDS=900
JWT_REFRESH_TTL_DAYS=30
PASSWORD_PEPPER=change_me_run_openssl_rand_hex_32

# --- Encryption (data at rest) ---
ENCRYPTION_KEY=change_me_run_openssl_rand_hex_32

# --- Anthropic Claude (Match matchmaking, dossiers) ---
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-opus-4-7

# --- OpenAI (embeddings, transcription, moderation) ---
OPENAI_API_KEY=
OPENAI_EMBEDDING_MODEL=text-embedding-3-large
OPENAI_TRANSCRIPTION_MODEL=whisper-1

# --- Hive AI (audio/image moderation) ---
HIVE_API_KEY=

# --- Voice fingerprinting microservice ---
VOICE_FINGERPRINT_URL=http://localhost:5000

# --- Twilio (SMS verification) ---
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_VERIFY_SERVICE_SID=

# --- Email (Resend) ---
RESEND_API_KEY=
EMAIL_FROM=Knot <hello@knot.app>

# --- Push notifications ---
EXPO_ACCESS_TOKEN=

# --- Identity verification (Onfido) ---
ONFIDO_API_TOKEN=
ONFIDO_REGION=eu

# --- Observability ---
SENTRY_DSN=
OTEL_EXPORTER_OTLP_ENDPOINT=
OTEL_SERVICE_NAME=knot-api

# --- Feature flags ---
FF_VOICE_TODAY_PROMPT=true
FF_MATCH_HUMAN_REVIEW=true

# --- Rate limits (overridable for testing) ---
RATE_LIMIT_AUTH_PER_MIN=5
RATE_LIMIT_FEED_READS_PER_MIN=60
